{
  "name": "gym-workout",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "VITE_APP_VERSION=$npm_package_version vite",
    "dev:mock": "VITE_APP_VERSION=$npm_package_version VITE_USE_MOCK_DATA=true vite",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --deny-warnings",
    "test": "vitest run",
    "check": "knip && oxlint --deny-warnings && npm run test && npm run build",
    "prebuild": "knip && oxlint --deny-warnings",
    "build": "VITE_APP_VERSION=$npm_package_version vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "knip": "^6.12.2",
    "oxlint": "^1.63.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
